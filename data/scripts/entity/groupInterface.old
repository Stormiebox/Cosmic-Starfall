function gI.DebugMsg(_text)
	if _debug then
		print(_myName.._text)
	end
end

function gI.Operated()
	if not(Entity()) or not(Player()) then return false end
	if Entity().index == _thisVeryPlayer.craftIndex then
		return true
	end

	return false
end
local isOperated = gI.Operated

local Debug = gI.DebugMsg
local TSR = Neltharaku.TableSelfReport

function gI.DoMeow()
	Debug('Meow')
end

--Ищет кнопку, которую нажали, в таблице, к которой она принадлежит. Дичь
--Сама кнопка в _element
--Таблица, в которой искать в _table
--Позиция кнопки в строке в _pos
function gI.getElementIndex(_element, _table, _pos)
	local _result = nil
	for _index,_rows in pairs(_table) do
		if _rows[_pos].index == _element.index then
			_result =_index
		end
	end
	return _result
end

